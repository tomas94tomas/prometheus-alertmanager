- name: 5. Gitlab Events
  rules:
  - alert: 5.1 gitlab_http_respose_yellow
    expr: probe_http_status_code{instance="gitlab.fltechnics.com", job="UI_APP_INFRASTRUCTURE_HTTPS"} != 200
    for: 1m
    labels:
      severity: event.yellow.gitlab
    annotations:
      Inpacted_Service : Gitlab
      Trigger : Exporter have status 0 or other of GitLab system {{ $labels.vhost }} HTTP error for 1m
      responsable: Dominykas Šivickas
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check FLT-GitLab (192.168.231.136) VM if available check Gitlab Docker container status. 
  - alert: 5.1 gitlab_http_respose_orange
    expr: probe_http_status_code{instance="gitlab.fltechnics.com", job="UI_APP_INFRASTRUCTURE_HTTPS"} != 200
    for: 10m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service : Gitlab
      Trigger : Exporter have status 0 or other of GitLab system {{ $labels.vhost }} HTTP error for 1m
      responsable: Dominykas Šivickas
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check FLT-GitLab (192.168.231.136) VM if available check Gitlab Docker container status. 
  - alert: 5.1 gitlab_http_respose_red
    expr: probe_http_status_code{instance="gitlab.fltechnics.com", job="UI_APP_INFRASTRUCTURE_HTTPS"} != 200
    for: 30m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : Gitlab
      Trigger : Exporter have status 0 or other of GitLab system {{ $labels.vhost }} HTTP error for 1m
      responsable: Andrius Kubickas
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Dominykas about GitLab availability and healthcheck
  - alert: 5.2 gitlab_db_activity_yellow
