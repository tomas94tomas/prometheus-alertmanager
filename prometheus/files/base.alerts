      summary: The Container analytics-rapiddeploy-server is DOWN
  - alert: Container analytics-sonarqube Down
    expr: sum(docker_container_running_state{ name ="analytics-sonarqube"}) without (__name__) == 0
    for: 10m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape for more than 10m,
        container may be down on server IP ={{ $labels.instance }}
      summary: The Container analytics-sonarqube is DOWN
  - alert: Container analytics-docker-shell-runner Down
    expr: sum(docker_container_running_state{ name ="analytics-docker-shell-runner"}) without (__name__) == 0
    for: 10m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape for more than 10m,
        container may be down on server IP ={{ $labels.instance }}
      summary: The Container analytics-docker-shell-runner is DOWN
  - alert: Container training-docker-shell-runner
    expr: sum(docker_container_running_state{ name ="training-docker-shell-runner"}) without (__name__) == 0
    for: 10m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape for more than 10m,
        container may be down on server IP ={{ $labels.instance }}
      summary: The Container training-docker-shell-runner is DOWN
- name: Bussnes systems Events
  rules:
  - alert: Bussines system UI HTTP error (Yellow)
    expr: probe_http_status_code{job="UI_APP_LIVE_HTTPS"} == 0 or probe_http_status_code{job="UI_APP_LIVE_HTTPS"} != 200
    for: 1m
    labels:
      severity: warning
    annotations:
      description: Exporter have status 0 ir 200 of Bussines system {{ $labels.vhost }} HTTP error
      summary: The Web UI {{ $labels.vhost }} is DOWN or Prometheus could not scrape.
  - alert: Bussines system UI HTTP error (Orange)
    expr: probe_http_status_code{job="UI_APP_LIVE_HTTPS"} == 0 or probe_http_status_code{job="UI_APP_LIVE_HTTPS"} != 200
    for: 10m
    labels:
      severity: event.orange
    annotations:
      description: Exporter have status 0 ir 200 of Bussines system {{ $labels.vhost }} HTTP error
      summary: The Web UI {{ $labels.vhost }} is DOWN or Prometheus could not scrape.
  - alert: Bussines system UI HTTP error (Red)
    expr: probe_http_status_code{job="UI_APP_LIVE_HTTPS"} == 0 or probe_http_status_code{job="UI_APP_LIVE_HTTPS"} != 200
    for: 15m
    labels:
      severity: event.red
    annotations:
      description: Exporter have status 0 ir 200 of Bussines system {{ $labels.vhost }} HTTP error
      summary: The Web UI {{ $labels.vhost }} is DOWN or Prometheus could not scrape.
  - alert: OUTSIDE Bussines system UI HTTP error 
    expr: probe_http_status_code{job="OUTSIDE_FLTECHNICS_HTTPS"} == 0 or probe_http_status_code{job="OUTSIDE_FLTECHNICS_HTTPS"} == 200
    for: 1m
    labels:
      severity: warning
    annotations:
      description: Exporter have status 0 ir 200 of Bussines system {{ $labels.vhost }} HTTP error
      summary: The Web UI {{ $labels.vhost }} is DOWN or Prometheus could not scrape.
- name: Jira Events
  rules:
  - alert: Alert for Insight sync SQL
    expr: mssql_insights_sync_sql == 0 and ON() hour() > 2 < 8
    for: 2m
    labels:
      {'env': 'jira'}
    annotations:
      description: Status change to 0.
      summary: Insight sync is not working
- name: AMOS WB 
  rules:
  - alert: Server AMOS Wheels And Brakes Down
    expr: up{job="AMOS Wheels and Brakes"} == 0
    for: 2m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape for more than 10m,
        server may be down 
      summary: The Server is DOWN or Prometheus could not scrape a {{ $labels.job }} exporter
  - alert: AMOS UAT Database Down
    expr: up{job="oracledb_exporter_wb_amos_uat"} == 0
    for: 5m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape for more than 10m,
        server may be down 
      summary: The Database is DOWN or Prometheus could not scrape a {{ $labels.job }} exporter
  - alert: AMOS TEST Database Down
    expr: up{job="oracledb_exporter_wb_amos_test"} == 0
    for: 5m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape for more than 10m,
        server may be down 
      summary: The Database is DOWN or Prometheus could not scrape a {{ $labels.job }} exporter
- name: IT support Unit Events
  rules:
  - alert: Server of IT Unit Support Down
    expr: up{job="IT Unit Support"} == 0
    for: 10m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape {{ $labels.name }} for more than 10m,
