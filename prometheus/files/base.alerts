    expr: mssql_entrance_KUN_HGR_kiosk_status + mssql_entrance_KUN_WH_kiosk_status + mssql_entrance_VNO_ADM_1a_1_kiosk_status + mssql_entrance_VNO_ADM_1a_2_kiosk_status + mssql_entrance_VNO_HGR_kiosk_status < 4
    for: 60m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : BI2 Kiosk 
      Trigger: bi2 Kiosk status >= 0 and time >= 60 min
      responsable: Vadimas Klepko
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Vadimas Klepko to check Kiosk is available or not. 
