    for: 5m
    labels:
      severity: event.yellow.gitlab
    annotations:
      Inpacted_Service : GitLab
      Trigger : Gitlab postgresql DB status >= 0 and time >= 5 min
      responsable: Dominykas Sivickas
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
