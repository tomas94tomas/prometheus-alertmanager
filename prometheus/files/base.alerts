groups:
- name: 1. Solarwinds Events
  rules:
  - alert: 1.1 SolarWinds_http_respose_yellow
    expr: probe_http_status_code{instance="https://sw.fltechnics.com", job="UI_APP_LIVE_HTTPS"} != 200
    for: 1m
    labels:
      severity: event.yellow.solarwinds
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: status 0 ir 200 of Solawinds DPA system {{ $labels.vhost }} HTTP error
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Dominykas to check Docker infrastructure
  - alert: 1.1 SolarWinds_http_respose_orange
    expr: probe_http_status_code{instance="https://sw.fltechnics.com", job="UI_APP_LIVE_HTTPS"} != 200
    for: 10m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: status 0 ir 200 of Solawinds DPA system {{ $labels.vhost }} HTTP error
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Fix 
  - alert: 1.1 SolarWinds_http_respose_red
    expr: probe_http_status_code{instance="https://sw.fltechnics.com", job="UI_APP_LIVE_HTTPS"} != 200
    for: 30m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: status 0 ir 200 of Solawinds DPA system {{ $labels.vhost }} HTTP error
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Dominykas, communication 
  - alert: 1.2 solarwinds_last_log_fltsql
    expr: solarwinds_last_log_fltsql > 10 or null
    for: 10m
    labels:
      severity: event.yellow.solarwinds
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: solarwinds_last_log_fltsql > 10 or null
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB. If DB is not available then start DB or restore DB. If DB available then ask Dominykas to check SolarWinds Docker container is live or not. If ODB-IT VM is down ask ASG to turn on VM
  - alert: 1.2 SolarWinds_last_Log_odb
    expr: solarwinds_last_log_odb > 15
    for: 10m
    labels:
      severity: event.yellow.solarwinds
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: solarwinds_last_log_odb > 10 or null
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB. If DB is not available then start DB or restore DB. If DB available then ask Dominykas to check SolarWinds Docker container is live or not. If ODB-IT VM is down ask ASG to turn on VM
  - alert: 1.2 SolarWinds_last_Lo_odbit
    expr: solarwinds_last_log_odbit > 10
    for: 10m
    labels:
      severity: event.yellow.solarwinds
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: solarwinds_last_log_odbit > 10 or null
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB. If DB is not available then start DB or restore DB. If DB available then ask Dominykas to check SolarWinds Docker container is live or not. If ODB-IT VM is down ask ASG to turn on VM
  - alert: 1.2 solarwinds_last_log_fltsql
    expr: solarwinds_last_log_fltsql > 10
    for: 30m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: solarwinds_last_log_fltsql > 10 or null
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check SolarWinds Docker container is live or not. If live ask Tomas to check DB availability.
  - alert: 1.2 SolarWinds_last_Log_odb
    expr: solarwinds_last_log_odb > 15
    for: 30m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: solarwinds_last_log_odb > 10 or null
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check SolarWinds Docker container is live or not. If live ask Tomas to check DB availability.
  - alert: 1.2 SolarWinds_last_Lo_odbit
    expr: solarwinds_last_log_odbit > 10
    for: 30m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: solarwinds_last_log_odbit > 10 or null
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check SolarWinds Docker container is live or not. If live ask Tomas to check DB availability.
  - alert: 1.2 solarwinds_last_log_fltsql
    expr: solarwinds_last_log_fltsql > 10
    for: 60m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: solarwinds_last_log_fltsql > 10 or null
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas and Dominykas to check SolarWinds Docker container and DB availabilities.
  - alert: 1.2 SolarWinds_last_Log_odb
    expr: solarwinds_last_log_odb > 15
    for: 60m
    labels:
      severity: event.red 
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: solarwinds_last_log_odb > 10 or null
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas and Dominykas to check SolarWinds Docker container and DB availabilities.
  - alert: 1.2 SolarWinds_last_Lo_odbit
    expr: solarwinds_last_log_odbit > 10
    for: 60m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service: Solarwinds
      Trigger: solarwinds_last_log_odbit > 10 or null
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas and Dominykas to check SolarWinds Docker container and DB availabilities.
- name: 2. QlikSense Events
  rules:
  - alert: 2.1 QlikSense_http_respose_yellow
    expr: probe_http_status_code{instance="https://bi.fltechnics.com", job="QLIKSENSE_HTTPS"} == 0
    for: 1m
    labels:
      severity: event.yellow.qliksense
    annotations:
      Inpacted_Service : Qlik Sense 
      Trigger : Exporter have status 0 or 200 of QlikSense system {{ $labels.vhost }} HTTP error for 1m
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check DB availability and Qlik Sense applications services statuses and startup DB or run services.
  - alert: 2.1 QlikSense_http_respose_orange
    expr: probe_http_status_code{instance="https://bi.fltechnics.com", job="QLIKSENSE_HTTPS"} == 0
    for: 10m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service: Qlik Sense 
      Trigger: Exporter have status 0 or 200 of QlikSense system {{ $labels.vhost }} HTTP error for 10m
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check DB availability and Qlik Sense applications services statuses and startup DB or run services.
  - alert: 2.1 QlikSense_http_respose_red
    expr: probe_http_status_code{instance="https://bi.fltechnics.com", job="QLIKSENSE_HTTPS"} == 0
    for: 30m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : Qlik Sense 
      Trigger: Exporter have status 0 or 200 of QlikSense system {{ $labels.vhost }} HTTP error for 30m
      responsable: Tomas Zemblys
      summary: The Web UI {{ $labels.vhost }} is DOWN or Prometheus could not scrape.
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check DB availability and Qlik Sense applications services statuses and startup DB or run services.
  - alert: 2.2 QlikSense_db_activity_yellow	
    expr: qlik_db_state < 1
    for: 10m
    labels:
      severity: event.yellow.qliksense
    annotations:
      Inpacted_Service: Qlik Sense 
      Trigger: QlikSense DB instance is down  VALUE = {{ $value }}
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB. If DB is not available then start DB or restore DB. If DB available then check Qlik Sense services is running or not. If flt-qlik-prod (192.168.50.104) VM or flt-qlik-prodr1 (192.168.50.52) VM is down ask ASG to turn on VM.
  - alert: 2.2 QlikSense_db_activity_orange	
    expr: qlik_db_state < 1
    for: 30m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service: Qlik Sense 
      Trigger: QlikSense DB instance is down  VALUE = {{ $value }}
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check Qlik Sense application services is running or not. If services is running ask Tomas to check DB availability.
  - alert: 2.2 QlikSense_db_activity_red
    expr: qlik_db_state < 1
    for: 60m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service: Qlik Sense 
      Trigger: QlikSense DB instance is down  VALUE = {{ $value }}
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas and Eligijus to check Qlik Sense application services is running and Qlik Sense DB is available or not. Ask Tomas or Eligijus to send communication for service downtime.
  - alert: 2.3 QlikSense_capacity_left_minutes_yellow
    expr: mssql_qlik_analyzer_capacity_lefttime{job="sql_exporter"} <= 200 or mssql_qlik_analyzer_capacity_lefttime{job="sql_exporter"} offset 18m or on() mssql_qlik_analyzer_capacity_lefttime{job="sql_exporter"}
    for: 30m
    labels:
      severity: event.yellow.qliksense
    annotations:
      Inpacted_Service: Qlik Sense 
      Trigger: QlikSense Capacity License left minutes = {{ $value }}
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check users with "Analyzer" license. Deallocate few users with oldest used date. Allocate these free licenses for users with biggest capacity minutes.
  - alert: 2.3 QlikSense_capacity_left_minutes_orange
    expr: mssql_qlik_analyzer_capacity_lefttime{job="sql_exporter"} <= 200 or mssql_qlik_analyzer_capacity_lefttime{job="sql_exporter"} offset 18m or on() mssql_qlik_analyzer_capacity_lefttime{job="sql_exporter"}
    for: 60m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service: Qlik Sense 
      Trigger: QlikSense Capacity License left minutes = {{ $value }}
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: 	Check users with "Analyzer" license. Deallocate few users with oldest used date. Allocate these free licenses for users with biggest capacity minutes.
  - alert: 2.3 QlikSense_capacity_left_minutes_red
    expr: mssql_qlik_analyzer_capacity_lefttime{job="sql_exporter"} <= 200 or mssql_qlik_analyzer_capacity_lefttime{job="sql_exporter"} offset 18m or on() mssql_qlik_analyzer_capacity_lefttime{job="sql_exporter"}
    for: 90m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service: Qlik Sense 
      Trigger: QlikSense Capacity License left minutes = {{ $value }}
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check users with "Analyzer" license. Deallocate few users with oldest used date. Allocate these free licenses for users with biggest capacity minutes.

  - alert: 2.4 QlikSense_failed_scheduler_tasks_yellow
    expr: qlik_sense_task_failed{job="sql_exporter"} > 0
    for: 30m
    labels:
      severity: event.yellow.qliksense
    annotations:
      Inpacted_Service: Qlik Sense 
      Trigger: QlikSense Failed scheduler tasks = {{ $value }} 
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check failed scheduler tasks and try to run these tasks. Identify scheduler task report and try load data manually. Try to solve connection problem for data retrieve or inform employee who can do it. 
      
  - alert: 2.4 QlikSense_failed_scheduler_tasks_orange
    expr: qlik_sense_task_failed{job="sql_exporter"} > 0
    for: 60m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service: Qlik Sense 
      Trigger: QlikSense Failed scheduler tasks = {{ $value }} 
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check failed scheduler tasks and try to run these tasks. Identify scheduler task report and try load data manually. Try to solve connection problem for data retrieve or inform employee who can do it. 

  - alert: 2.4 QlikSense_failed_scheduler_tasks_red
    expr: qlik_sense_task_failed{job="sql_exporter"} > 0
    for: 90m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service: Qlik Sense 
      Trigger: QlikSense Failed scheduler tasks = {{ $value }} 
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Rasita or Tomas to check failed scheduler tasks.  
- name: 3. MSSQL Events
  rules:
  - alert: 3.1 FLTSQL_master_db_activity_yellow
    expr: mssql_fltsql_db_service_state == 0 or absent(mssql_fltsql_db_service_state)
    for: 10m
    labels:
      severity: event.yellow.mssql
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL db activity > 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB. If DB is not available then start DB or restore DB. If DB available then check MSSQL services is running or not on FLTSQL server. If FLTSQL (192.168.50.10) VM is down ask ASG to turn on VM.
  - alert: 3.1 FLTSQL_master_db_activity_orange
    expr: mssql_fltsql_db_service_state == 0 or absent(mssql_fltsql_db_service_state)
    for: 15m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL db activity > 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB. If DB is not available then start DB or restore DB. If DB available then check MSSQL services is running or not on FLTSQL server. If FLTSQL (192.168.50.10) VM is down ask ASG to turn on VM.
  - alert: 3.1 FLTSQL_master_db_activity_red
    expr: mssql_fltsql_db_service_state == 0 or absent(mssql_fltsql_db_service_state)
    for: 20m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL db activity > 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas to check FLTSQL DB is available or not. Ask Tomas send communication for service downtime. 
  - alert: 3.2 FLTSQL_others_db_activity_yellow
    expr: mssql_fltsql_others_db_activity == 0 or absent(mssql_fltsql_others_db_activity)
    for: 10m
    labels:
      severity: event.yellow.mssql
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL others db activity > 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB mentioned in the alert. If DB is not available then start DB or restore DB. If DB available then check MSSQL services is running or not on FLTSQL server. If FLTSQL (192.168.50.10) VM is down ask ASG to turn on VM.
  - alert: 3.2 FLTSQL_others_db_activity_orange
    expr: mssql_fltsql_others_db_activity == 0 or absent(mssql_fltsql_others_db_activity)
    for: 15m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL others db activity >  15 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB mentioned in the alert. If DB is not available then start DB or restore DB. If DB available then check MSSQL services is running or not on FLTSQL server. If FLTSQL (192.168.50.10) VM is down ask ASG to turn on VM.
  - alert: 3.2 FLTSQL_others_db_activity_red
    expr: mssql_fltsql_others_db_activity == 0 or absent(mssql_fltsql_others_db_activity)
    for: 20m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL others db activity > 20 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas to check FLTSQL DB is available or not. Ask Tomas send communication for DB's downtime .
  - alert: 3.3 FLTSQL_blocking_sessions_yellow
    expr: windows_mssql_genstats_blocked_processes > 0
    for: 5m
    labels:
      severity: event.yellow.mssql
    annotations:
      Inpacted_Service : MSSQL
      Trigger : Blocking sessions count = <1 and time >= 5 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check blocked sessions of FLTSQL server. Kill session of the blocker.
  - alert: 3.3 FLTSQL_blocking_sessions_orange
    expr: windows_mssql_genstats_blocked_processes > 0
    for: 10m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service : MSSQL
      Trigger : blocking sessions count = <1 and time >= 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check blocked sessions of FLTSQL server. Kill session of the blocker.
  - alert: 3.3 FLTSQL_blocking_sessions_red
    expr: windows_mssql_genstats_blocked_processes > 0
    for: 20m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : MSSQL
      Trigger : blocking sessions count = <1 and time >= 20 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas to check FLTSQL server blocked sessions and kill session of the blocker.
  - alert: 3.4 FLTSQL_linked_servers_yellow
    expr: mssql_linked_servers_failed{job="sql_exporter"} == 1
    for: 5m
    labels:
      severity: event.yellow.mssql
    annotations:
      Inpacted_Service : MSSQL
      Trigger : linked servers count >= 1
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check failed linked server in FLTSQL. Identify reason of linked server fail and fix it.
  - alert: 3.4 FLTSQL_linked_servers_orange
    expr: mssql_linked_servers_failed{job="sql_exporter"} == 1
    for: 15m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service : MSSQL
      Trigger : linked servers count >= 1
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check failed linked server in FLTSQL. Identify reason of linked server fail and fix it.
  - alert: 3.4 FLTSQL_linked_servers_red
    expr: mssql_linked_servers_failed{job="sql_exporter"} == 1
    for: 20m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : MSSQL
      Trigger : linked servers count >= 1
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas to check failed linked server in FLTSQL and ask to fix failed linked server.	
  - alert: 3.5 FLTTRAIN_master_db_activity_yellow
    expr: mssql_fltrain_db_service_state == 0 or absent(mssql_fltrain_db_service_state)
    for: 10m
    labels:
      severity: event.yellow.mssql
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL db activity > 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB. If DB is not available then start DB or restore DB. If DB available then check MSSQL services is running or not on FLTSQL server. If FLTSQL (192.168.50.10) VM is down ask ASG to turn on VM.
  - alert: 3.5 FLTTRAIN_master_db_activity_orange
    expr: mssql_fltrain_db_service_state == 0 or absent(mssql_fltrain_db_service_state)
    for: 15m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL db activity > 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB. If DB is not available then start DB or restore DB. If DB available then check MSSQL services is running or not on FLTSQL server. If FLTSQL (192.168.50.10) VM is down ask ASG to turn on VM.
  - alert: 3.5 FLTTRAIN_master_db_activity_red
    expr: mssql_fltrain_db_service_state == 0 or absent(mssql_fltrain_db_service_state)
    for: 20m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL db activity > 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas to check FLTSQL DB is available or not. Ask Tomas send communication for service downtime. 
  - alert: 3.6 FLTTRAIN_others_db_activity_yellow
    expr: mssql_fltrain_others_db_activity == 0
    for: 10m
    labels:
      severity: event.yellow.mssql
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL others db activity > 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB mentioned in the alert. If DB is not available then start DB or restore DB. If DB available then check MSSQL services is running or not on FLTSQL server. If FLTTrain (192.168.50.18) VM is down ask ASG to turn on VM.
  - alert: 3.6 FLTTRAIN_others_db_activity_orange
    expr: mssql_fltrain_others_db_activity == 0
    for: 20m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL others db activity >  20 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available DB mentioned in the alert. If DB is not available then start DB or restore DB. If DB available then check MSSQL services is running or not on FLTSQL server. If FLTTrain (192.168.50.18) VM is down ask ASG to turn on VM.
  - alert: 3.6 FLTTRAIN_others_db_activity_red
    expr: mssql_fltrain_others_db_activity == 0
    for: 30m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : MSSQL
      Trigger : MSSQL others db activity > 20 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas to check FLTTrain DB is available or not. Ask Tomas send communication for DB's downtime .
  - alert: 3.7 FLTTRAIN_blocking_sessions_yellow
    expr: wmi_mssql_genstats_blocked_processes{job="FLTTRAIN_metrics"} == 1
    for: 10m
    labels:
      severity: event.yellow.mssql
    annotations:
      Inpacted_Service : MSSQL
      Trigger : Blocking sessions count = 1 and time >= 5 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check blocked sessions of FLTSQL server. Kill session of the blocker.
  - alert: 3.7 FLTTRAIN_blocking_sessions_orange
    expr: wmi_mssql_genstats_blocked_processes{job="FLTTRAIN_metrics"} == 2
    for: 10m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service : MSSQL
      Trigger : blocking sessions count = 2 and time >= 5 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check blocked sessions of FLTTrain server. Kill session of the blocker.
  - alert: 3.7 FLTTRAIN_blocking_sessions_red
    expr: wmi_mssql_genstats_blocked_processes{job="FLTTRAIN_metrics"} >= 3
    for: 10m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : MSSQL
      Trigger : blocking sessions count = 3 and time >= 5 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas to check FLTTrain server blocked sessions and kill session of the blocker.
- name: 4. ODB Events
  rules:
  - alert: 4.1 ODB_sysdba_alert_yellow
    expr: oracledb_connections_idle_sec{program="QCSYSMOD.EXE", user_name="SYSDBA"} or oracledb_connections_idle_sec{program="qcsysmod.exe", user_name="SYSDBA"} 
    for: 4m
    labels:
      severity: event.yellow.eams
    annotations:
      Inpacted_Service : ODB
      Trigger : (upper(program) = "QCSYSMOD.EXE") AND (upper(user_name) = "SYSDBA")
      responsable: Karolis Kondra
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Connect user, ask to disconnect or reconnect with own username. Ask for reason why system user was used.
  - alert: 4.1 ODB_sysdba_alert_orange
    expr: oracledb_connections_idle_sec{program="QCSYSMOD.EXE", user_name="SYSDBA"} 
    for: 20m
    labels:
      severity: event.orange.eams
    annotations:
      Inpacted_Service : ODB
      Trigger : (upper(program) = "QCSYSMOD.EXE") AND (upper(user_name) = "SYSDBA")
      responsable: Karolis Kondra
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Connect user, ask to disconnect or reconnect with own username. Ask for reason why system user was used.
  - alert: 4.1 ODB_sysdba_alert_red
    expr: oracledb_connections_idle_sec{program="QCSYSMOD.EXE", user_name="SYSDBA"} 
    for: 40m
    labels:
      severity: event.red.eams
    annotations:
      Inpacted_Service : ODB
      Trigger : (upper(program) = "QCSYSMOD.EXE") AND (upper(user_name) = "SYSDBA")
      responsable: Karolis Kondra
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Connect user, ask to disconnect or reconnect with own username. Ask for reason why system user was used. Kill user session.
  - alert: 4.2 ODB_db_activity_yellow
    expr: oracledb_up {job="oracledb_exporter"} == 0 or absent(oracledb_up {job="oracledb_exporter"})
    for: 10m
    labels:
      severity: event.yellow.odb
    annotations:
      Inpacted_Service : ODB
      Trigger : db activity > 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available Oracle DB CCTL instance. If DB is not available then start DB or restore DB. If DB available then check Oracle DB CCTL instance services is running or not on ODB server. If ODB (192.168.50.180) VM is down ask ASG to turn on VM.
  - alert: 4.2 ODB_db_activity_orange
    expr: oracledb_up {job="oracledb_exporter"} == 0 or absent(oracledb_up {job="oracledb_exporter"})
    for: 20m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service : ODB
      Trigger : db activity > 15 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check if available Oracle DB CCTL instance. If DB is not available then start DB or restore DB. If DB available then check Oracle DB CCTL instance services is running or not on ODB server. If ODB (192.168.50.180) VM is down ask ASG to turn on VM.
  - alert: 4.2 ODB_db_activity_red
    expr: oracledb_up {job="oracledb_exporter"} == 0 or absent(oracledb_up {job="oracledb_exporter"})
    for: 40m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : ODB
      Trigger : db activity > 20 min
      responsable: Andrius Kubickas
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Ask Tomas to check ODB (192.168.50.180) VM Oracle DB CCTL instance is available or not. Ask Tomas send communication for service downtime.
  - alert: 4.3 ODB_blocking_sessions_yellow
    expr: oracledb_resource_current_utilization{job="oracledb_exporter", resource_name="temporary_table_locks"} > 0
    for: 10m
    labels:
      severity: event.yellow.odb
    annotations:
      Inpacted_Service : ODB
      Trigger : db activity > 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check blocked sessions of ODB server CCTL instance. Kill session of the blocker.
  - alert: 4.3 ODB_blocking_sessions_orange
    expr: oracledb_resource_current_utilization{job="oracledb_exporter", resource_name="temporary_table_locks"} > 1
    for: 10m
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service : ODB
      Trigger : db activity > 10 min
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check blocked sessions of ODB server CCTL instance. Kill session of the blocker.
  - alert: 4.3 ODB_blocking_sessions_red
    expr: oracledb_resource_current_utilization{job="oracledb_exporter", resource_name="temporary_table_locks"} > 2
    for: 10m
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : ODB
      Trigger : db activity > 10 min
      responsable: Andrius Kubickas
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check blocked sessions of ODB server CCTL instance. Kill session of the blocker.
  - alert: 4.4. ODB_D_disk_space_yellow
    expr: label_replace(({__name__=~"^windows_logical_disk_size_bytes.*", job=~"ODB_metrics", volume="D:"} - {__name__=~"^windows_logical_disk_free_bytes.*", job=~"ODB_metrics", volume="D:"}) / {__name__=~"^windows_logical_disk_size_bytes.*", job=~"ODB_metrics",volume="D:"} * 100, "name", "$1", "__name__", "(.*)" ) > 85
    for: 10m
    labels:
      severity: event.yellow.odb
    annotations:
      Inpacted_Service : ODB
      Trigger : used disk space >= 85% 
      responsable: Tomas Zemblys
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check free space of ODB server drive D (installed Oracle DB for Quantum). If need more space ask Dominykas to order more resources.
  - alert: 4.4. ODB_D_disk_space_orange
    expr: label_replace(({__name__=~"^windows_logical_disk_size_bytes.*", job=~"ODB_metrics", volume="D:"} - {__name__=~"^windows_logical_disk_free_bytes.*", job=~"ODB_metrics", volume="D:"}) / {__name__=~"^windows_logical_disk_size_bytes.*", job=~"ODB_metrics",volume="D:"} * 100, "name", "$1", "__name__", "(.*)" ) > 90
    for: 10m
