    annotations:
      description: Prometheus could not scrape for more than 10m,
        server may be down 
      summary: The Server is DOWN or Prometheus could not scrape a {{ $labels.job }} exporter
- name: HashiCorp Cluster Events
  rules:
  - alert: Server of RND DEV orchestration cluster Down
