- name: Files Events
  rules:
  - alert: File_server_availability_yellow
    expr: up{job="IT Unit Support",name="FLT-Files"} == 0
    for: 3m
    labels:
      severity: event.yellow.files
    annotations:
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      responsable: Konstantinas Starkutis
      Trigger: Server is unavailable
      Inpacted_Service: Files Server
      Action: Check server availability.

  - alert: File_server_availability_orange
    expr: up{job="IT Unit Support",name="FLT-Files"} == 0
    for: 10m 
    labels:
      severity: event.orange
    annotations:
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      responsable: Konstantinas Starkutis
      Trigger: Server is unavailable
      Inpacted_Service: Files Server
      Action: Check server availability.

  - alert: File_server_availability_red
    expr: up{job="IT Unit Support",name="FLT-Files"} == 0
    for: 10m 
    labels:
      severity: event.red
    annotations:
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      responsable: Konstantinas Starkutis
      Trigger: Server is unavailable
      Inpacted_Service: Files Server
      Action: Check server availability.

  - alert: File_server_DiskUsage_yellow
    expr: 100 - 100 * ((windows_logical_disk_free_bytes{instance="FLT-Files", volume!~"R:"} / 1024 / 1024) / (windows_logical_disk_size_bytes{instance="FLT-Files",volume!~"R:"} / 1024 / 1024)) > 98
    for: 10m
    labels:
      severity: event.yellow.files
    annotations:
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      responsable: Konstantinas Starkutis
      Trigger: Disk usage is more than 95%
      Inpacted_Service: Files Server
      Action: Check server Disk Uasge 

  - alert: File_server_DiskUsage_orange
    expr: 100 - 100 * ((windows_logical_disk_free_bytes{instance="FLT-Files", volume!~"R:"} / 1024 / 1024) / (windows_logical_disk_size_bytes{instance="FLT-Files",volume!~"R:"} / 1024 / 1024)) > 98
    for: 30m
    labels:
      severity: event.orange
    annotations:
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      responsable: Konstantinas Starkutis
      Trigger: Disk usage is more than 95%
      Inpacted_Service: Files Server
      Action: Check server Disk Uasge 

  - alert: File_server_DiskUsage_red
    expr: 100 - 100 * ((windows_logical_disk_free_bytes{instance="FLT-Files", volume!~"R:"} / 1024 / 1024) / (windows_logical_disk_size_bytes{instance="FLT-Files",volume!~"R:"} / 1024 / 1024)) > 98 
    for: 60m
    labels:
      severity: event.red
    annotations:
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      responsable: Konstantinas Starkutis
      Trigger: Disk usage is more than 95%
      Inpacted_Service: Files Server
      Action: Check server Disk Uasge