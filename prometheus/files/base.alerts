- name: Linux Server Events
  rules:
  - record: instance:node_cpu:rate:sum
    expr: sum(rate(node_cpu{mode!="idle",mode!="iowait"}[3m]))
      BY (instance)
  - record: instance:node_filesystem_usage:sum
    expr: sum((node_filesystem_size{mountpoint="/"} - node_filesystem_free{mountpoint="/"}))
      BY (instance)
  - record: instance:node_network_receive_bytes:rate:sum
    expr: sum(rate(node_network_receive_bytes[3m])) BY (instance)
  - record: instance:node_network_transmit_bytes:rate:sum
    expr: sum(rate(node_network_transmit_bytes[3m])) BY (instance)
  - record: instance:node_cpu:ratio
    expr: sum(rate(node_cpu{mode!="idle",mode!="iowait"}[5m])) WITHOUT (cpu, mode) / ON(instance)
      GROUP_LEFT() count(sum(node_cpu) BY (instance, cpu)) BY (instance)
  - record: cluster:node_cpu:sum_rate5m
    expr: sum(rate(node_cpu{mode!="idle",mode!="iowait"}[5m]))
  - record: cluster:node_cpu:ratio
    expr: cluster:node_cpu:rate5m / count(sum(node_cpu) BY (instance, cpu))
  - alert: NodeDiskRunningFull (Predicted within 24 hours)
    expr: predict_linear(node_filesystem_free[6h], 3600 * 24) < 0
    for: 30m
    labels:
      severity: warning
    annotations:
      description: device {{$labels.device}} on node {{$labels.instance}} is running
        full within the next 24 hours (mounted at {{$labels.mountpoint}})
      summary: Node disk is running full within 24 hours
  - alert: NodeDiskRunningFull (Predicted within 2 hours)
    expr: predict_linear(node_filesystem_free[30m], 3600 * 2) < 0
    for: 10m
    labels:
      severity: warning
    annotations:
      description: device {{$labels.device}} on node {{$labels.instance}} is running
        full within the next 2 hours (mounted at {{$labels.mountpoint}})
      summary: Node disk is running full within 2 hours
  - alert: HostSwapIsFillingUp
    expr: (1 - (node_memory_SwapFree_bytes / node_memory_SwapTotal_bytes)) * 100 > 90
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: Host swap is filling up (instance {{ $labels.instance }})
      description: "Swap is filling up (>80%)\n  VALUE = {{ $value }}\n  LABELS = {{ $labels }}"
  - alert: HostProcessOverload
    expr: node_procs_running > 40
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: Host is have 40 Proces o (instance {{ $labels.instance }})
      description: "Proces is overloading  VALUE = {{ $value }}\n  LABELS = {{ $labels }}"
  - alert: HostMemoryUnderMemoryPressure
    expr: rate(node_vmstat_pgmajfault[1m]) > 1000
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: Host memory under memory pressure (instance {{ $labels.instance }})
      description: "The node is under heavy memory pressure. High rate of major page faults\n  VALUE = {{ $value }}\n  LABELS = {{ $labels }}"
  - alert: LowMemory
    expr:  100 - ((node_memory_MemAvailable_bytes * 100) / node_memory_MemTotal_bytes) > 85
    for: 5m
    labels:
      severity: warning
    annotations:
      text: '{{ $labels.name }} memory usage is {{ $value }}.'
  - alert: High_CPU_Usage
    expr: 100 - (avg by(instance) (irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 90
    for: 1m
    annotations:
      description: '{{ $labels.name }} CPU usage has exceeded the threshold with a value of {{ $value }}.'
      summary: Instance {{ $labels.instance }} CPU usage is dangerously high
  - alert: TooManyOpenFileDescriptors
    expr: 100 * (process_open_fds / process_max_fds) > 95
    for: 10m
    labels:
      severity: critical
    annotations:
      description: '{{$labels.name }}) is using {{ $value }}% of the available file/socket descriptors.'
      summary: too many open file descriptors
  - alert: DiskRunningFull
    expr: 100 - ((node_filesystem_avail_bytes{mountpoint="/",fstype!="rootfs"} * 100) / node_filesystem_size_bytes{mountpoint="/",fstype!="rootfs"}) > 100
    for: 10m
    labels:
      severity: warning
    annotations:
      description: device {{$labels.device}} on node {{$labels.instance}} is running
        full within the next 24 hours (mounted at {{$labels.mountpoint}})
      summary: Node disk is running full 
  - alert: Disk_90proc
    expr: 100 - ((node_filesystem_avail_bytes{mountpoint="/",fstype!="rootfs"} * 100) / node_filesystem_size_bytes{mountpoint="/",fstype!="rootfs"}) > 90
    for: 5m
    labels:
      severity: warning
    annotations:
      description: device {{$labels.device}} on node {{$labels.instance}} is running
        80% within the next 24 hours (mounted at {{$labels.mountpoint}})
      summary: Node disk is running on 90%
  - alert: HostUnusualDiskReadRate
    expr: sum by (instance) (rate(node_disk_read_bytes_total[2m])) / 1024 / 1024 > 50
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate (instance {{ $labels.instance }})
      description: "Disk is probably reading too much data (> 50 MB/s)\n  VALUE = {{ $value }}\n  LABELS = {{ $labels }}"
  - alert: DiskisnearFull
    expr: 100 - ((node_filesystem_avail_bytes{mountpoint="/",fstype!="rootfs"} * 100) / node_filesystem_size_bytes{mountpoint="/",fstype!="rootfs"}) > 85
    for: 10m
    labels:
      severity: warning
    annotations:
      description: device {{$labels.device}} on node {{$labels.instance}} is running
        65% within the next 24 hours (mounted at {{$labels.mountpoint}})
      summary: Node disk is running on 70%
  - alert: HostUnusualNetworkThroughputIn
    expr: sum by (instance) (rate(node_network_receive_bytes_total[2m])) / 1024 / 1024 > 100
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual network throughput in (instance {{ $labels.instance }})
      description: "Host network interfaces are probably receiving too much data (> 100 MB/s)\n  VALUE = {{ $value }}\n  LABELS = {{ $labels }}"
  - alert: HostUnusualNetworkThroughputOut 
    expr: sum by (instance) (rate(node_network_transmit_bytes_total[2m])) / 1024 / 1024 > 100
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host unusual network throughput out (instance {{ $labels.instance }})
      description: "Host network interfaces are probably sending too much data (> 100 MB/s)\n  VALUE = {{ $value }}\n  LABELS = {{ $labels }}"
- name: MSSQL Events
  rules:
  - alert: Server FLTSQL Down
    expr: up{job="FLTSQL_metrics"} == 0
    for: 10m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape for more than 10m,
        server may be down 
      summary: The Server is DOWN or Prometheus could not scrape a {{ $labels.job }} exporter
  - alert: DB service of FLTSQL Down
    expr: mssql_fltsql_db_service_state == 0
    for: 5m
    labels:
      severity: warning
    annotations:
      description: DB service of FLTSQL Down
      summary: FLTSQL database may not work
  - alert: DB service of FLTrain Down
    expr: mssql_fltrain_db_service_state == 0
    for: 5m
    labels:
      severity: warning
    annotations:
      description: DB service of FLTSQL Down
      summary: FLTSQL database may not work
  - alert: Server FLTTRAIN Down
    expr: up{job="FLTTRAIN_metrics"} == 0
    for: 10m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape for more than 10m,
        server may be down 
      summary: The Server is DOWN or Prometheus could not scrape a {{ $labels.job }} exporter
  - alert: Server FLT App (Ramco application server) Down
    expr: up{job="FLTapp"} == 0
    for: 10m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape for more than 10m,
        server may be down 
      summary: The Server is DOWN or Prometheus could not scrape a {{ $labels.job }} exporter
  - alert: Server KYC Database Down
    expr: up{job="KYC_DB_metrics"} == 0
    for: 10m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape for more than 10m,
        server may be down 
      summary: The Server is DOWN or Prometheus could not scrape a {{ $labels.job }} exporter      
- name: ODB Events
  rules:
  - alert: ODB Service Down
    expr: oracledb_up < 1
    for: 1m
    labels:
      severity: warning
    annotations:
      summary: Oracle DB service (not whole server) down (instance {{ $labels.instance }})
      description: "Oracle Service instance is down\n  VALUE = {{ $value }}\n  LABELS = {{ $labels }}"
  - alert: ODB Server dml_locks
    expr: avg_over_time(oracledb_resource_current_utilization{resource_name="dml_locks"}[10m]) > 200
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: ODB Server dml_locks (instance {{ $labels.instance }})
      description: "ODB Server is having some dml_locks.\n  VALUE = {{ $value }}\n  LABELS = {{ $labels }}"
  - alert: Server ODB Database Down
    expr: up{job="ODB_metrics"} == 0
    for: 10m
    labels:
      severity: warning
    annotations:
      description: Prometheus could not scrape for more than 10m,
        server may be down 
      summary: The Server is DOWN or Prometheus could not scrape a {{ $labels.job }} exporter
