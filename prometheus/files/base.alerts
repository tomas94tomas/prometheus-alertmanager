- name: 29. ServerBackups
  rules:
  - alert: 29.1 Server_backups_failed_yellow
    expr: server_backups_failed != 0
    for: 1h
    labels:
      severity: event.yellow.backups
    annotations:
      Inpacted_Service : Server Backups
      Trigger : If Failed status is more than 0 for 30m
      responsable: Dominykas Šivickas
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check Servers Failed Backups, write ticket to ASG if failing periodically.
  - alert: 29.1 Server_backups_failed_orange
    expr: server_backups_failed != 0
    for: 3h
    labels:
      severity: event.orange
    annotations:
      Inpacted_Service : Server Backups
      Trigger : If Failed status is more than 0 for 3h
      responsable: Dominykas Šivickas
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check Servers Failed Backups, write ticket to ASG if failing periodically.
  - alert: 29.1 Server_backups_failed_red
    expr: server_backups_failed != 0
    for: 24h
    labels:
      severity: event.red
    annotations:
      Inpacted_Service : Server Backups
      Trigger : If Failed status is more than 0 for 24h
      responsable: Dominykas Šivickas
      timestamp: >
        time: {{ with query "time()" }}{{ . | first | value | humanizeTimestamp }}{{ end }}
      Action: Check Servers Failed Backups, write ticket to ASG if failing periodically.
